# =============================================================
# GemData Environment Configuration
# =============================================================
# This file documents ALL secrets and config overrides needed
# for production. The actual values go in gemdata-config.php
# (placed OUTSIDE public_html, at /home/yyrigitd/gemdata-config.php).
#
# This file is NOT loaded by the application — it exists only
# as a reference for developers and deployment checklists.
# =============================================================

# --- Application ---
APP_ENV=production
APP_BASE_URL=
APP_PUBLIC_ORIGIN=https://gemdata.com.ng

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yyrigitd_gemdata
DB_USERNAME=yyrigitd_dbuser
DB_PASSWORD=__CHANGE_ME__

# --- Payments (Paystack) ---
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_BASE_URL=https://api.paystack.co

# --- DVA (Dedicated Virtual Accounts) ---
PAYSTACK_DVA_BANK=wema-bank

# --- ZenithPay Virtual Accounts ---
# Use your real live token here. Placeholder values are treated as not configured.
ZENITHPAY_SECRET_KEY=__REPLACE_WITH_ZENITHPAY_LIVE_TOKEN__
ZENITHPAY_BASE_URL=https://zenithpay.ng
ZENITHPAY_AUTO_ASSIGN=true
ZENITHPAY_WEBHOOK_URL=https://gemdata.com.ng/api/zenithpay-webhook.php
# Comma-separated exact ZenithPay dashboard IPs only.
ZENITHPAY_ALLOWED_IPS=

# --- Webhooks ---
WEBHOOK_SHARED_SECRET=__GENERATE_RANDOM_64_CHARS__

# --- Mail/SMTP ---
MAIL_DRIVER=smtp
MAIL_FROM_ADDRESS=support@gemdata.com.ng
MAIL_FROM_NAME=GemData
MAIL_HOST=mail.gemdata.com.ng
MAIL_PORT=465
MAIL_USERNAME=support@gemdata.com.ng
MAIL_PASSWORD=__CHANGE_ME__

# --- VTU Provider Credentials ---
# Each provider's api_key and api_secret go into the
# providers array in gemdata-config.php.
ALBANI_API_KEY=
SMEPLUG_API_KEY=
SMEPLUG_API_SECRET=
VTPASS_API_KEY=
VTPASS_API_SECRET=

# --- JWT (if future mobile auth is added) ---
JWT_SECRET=__GENERATE_RANDOM_64_CHARS__

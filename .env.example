# =============================================================
# GemData Environment Configuration
# =============================================================
# This file documents ALL secrets and config overrides needed
# for production. The actual values go in gemdata-config.php
# (placed OUTSIDE public_html, at /home/yyrigitd/gemdata-config.php).
#
# This file is NOT loaded by the application — it exists only
# as a reference for developers and deployment checklists.
# =============================================================

# --- Application ---
APP_ENVIRONMENT=production
APP_BASE_URL=
APP_PUBLIC_ORIGIN=https://gemdata.com.ng

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yyrigitd_gemdata
DB_USER=yyrigitd_dbuser
DB_PASS=__CHANGE_ME__

# --- Payments (XixaPay) ---
XIXAPAY_API_KEY=__CHANGE_ME__
XIXAPAY_API_SECRET=__CHANGE_ME__
XIXAPAY_BUSINESS_ID=__CHANGE_ME__
XIXAPAY_BASE_URL=https://api.xixapay.com
XIXAPAY_BANK_CODES=20867
XIXAPAY_WEBHOOK_URL=https://gemdata.com.ng/api/xixapay.php

# --- Payments (KatPay) ---
KATPAY_ENABLED=false
KATPAY_API_KEY=__CHANGE_ME__
KATPAY_SECRET_KEY=__CHANGE_ME__
KATPAY_BASE_URL=https://api.katpay.co/v1
KATPAY_MERCHANT_ID=__CHANGE_ME__
KATPAY_BANK_CODES=PALMPAY,OPAY

# --- Webhooks ---
WEBHOOK_SHARED_SECRET=__GENERATE_RANDOM_64_CHARS__

# --- Mail/SMTP ---
MAIL_DRIVER=smtp
MAIL_FROM_EMAIL=support@gemdata.com.ng
MAIL_FROM_NAME=GemData
SMTP_HOST=mail.gemdata.com.ng
SMTP_PORT=465
SMTP_USER=support@gemdata.com.ng
SMTP_PASS=__CHANGE_ME__

# --- VTU Provider Credentials ---
# Each provider's api_key and api_secret go into the
# providers array in gemdata-config.php.
ALBANI_API_KEY=
SMEPLUG_API_KEY=
SMEPLUG_API_SECRET=
VTPASS_API_KEY=
VTPASS_API_SECRET=

# --- JWT (if future mobile auth is added) ---
JWT_SECRET=__GENERATE_RANDOM_64_CHARS__
